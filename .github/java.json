{
    "problemMatcher": [
        {
            "owner": "java",
            "pattern": [
                {
                    "regexp": "^Exception in thread \"(.*)\" (.*): (.*)$",
                    "code": 2,
                    "message": 3
                }
            ]
        },
        {
            "owner": "javac",
            "pattern": [
                {
                    "regexp": "^([^:]+):(\\d+): (warning|error): (.+?)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "message": 4
                }
            ]
        },
        {
            "owner": "maven-javac",
            "pattern": [
                {
                    "regexp": "^\\[(WARNING|ERROR)\\]\\s+(.+?\\.java):\\[(\\d+),(\\d+)\\]\\s+(.+)$",
                    "severity": 1,
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "message": 5
                }
            ]
        }
    ]
}
